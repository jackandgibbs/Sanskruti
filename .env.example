# Copy this file to .env and fill in real values. See SETUP.md for where each comes from.
# Only VITE_-prefixed vars are exposed to the browser. The anon key is safe to expose
# because Row Level Security (see supabase/schema.sql) protects the data.

# --- Supabase: Dashboard → Project Settings → API ---
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"

# --- Cloudinary: cloud name from Dashboard; preset from Settings → Upload (unsigned) ---
VITE_CLOUDINARY_CLOUD_NAME="YOUR-CLOUD-NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="YOUR-UNSIGNED-PRESET"
