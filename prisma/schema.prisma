generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String   @id @default(uuid())
  customerId     String   @unique
  firstName      String
  lastName       String
  phone          String   @unique
  otpVerified    Boolean  @default(false)
  gender         String?  // 'Male', 'Female', 'Other'
  addressStreet  String?
  addressCity    String?
  addressState   String?
  addressZip     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
}

model Product {
  id             String   @id @default(uuid())
  // Basic Info
  name           String
  description    String?
  category       String
  
  // Identifiers
  sku            String?  @unique
  barcode        String?

  // Pricing
  price          Float    // Selling price
  mrp            Float?   // Original MRP
  costPrice      Float?   // Internal cost
  taxRate        Float    @default(0)

  // Variations & Inventory
  sizes          String?  // Stored as JSON or comma-separated: "XS,S,M,L"
  color          String?
  inStock        Boolean  @default(true)
  stockCount     Int      @default(0)
  
  // Craft & Logistics
  fabric         String?
  craftType      String?  // e.g. Bandhani, Zari
  washCare       String?
  weightGrams    Int?
  dispatchDays   String?  // e.g. "Ships in 3-5 days"

  // Marketing & Media
  bestSeller     Boolean  @default(false)
  newArrival     Boolean  @default(false)
  tags           String?  // Comma separated
  metaTitle      String?
  metaDesc       String?
  
  // Images (URLs)
  image          String
  hoverImage     String?
  galleryImages  String?  // Stored as JSON array string

  // Stats
  rating         Float    @default(0)
  reviews        Int      @default(0)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orderItems     OrderItem[]
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  status         String      @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED
  totalAmount    Float
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
